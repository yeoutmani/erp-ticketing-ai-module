# ── Frontend ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx

# ── Supabase (server-side) ──────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ── n8n ─────────────────────────────────────────────
N8N_PORT=5678
N8N_HOST=0.0.0.0          # ← was localhost, must be 0.0.0.0 in Docker
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password
N8N_ENCRYPTION_KEY=change_me_random_32_chars_minimum
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# ── AI Service ──────────────────────────────────────
AI_TIMEOUT_MS=30000
AI_CONFIDENCE_THRESHOLD=0.75
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://ollama:11434   # ← nom du service Docker, pas localhost

# ── Nginx ───────────────────────────────────────────
DOMAIN=erp.yourdomain.com
N8N_PATH=/n8n/
WEBHOOK_URL=http://localhost/n8n/

ERP_DOMAIN=erp.yourdomain.com